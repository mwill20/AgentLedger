# Database
DATABASE_URL=postgresql+asyncpg://agentledger:agentledger@db:5432/agentledger
DATABASE_URL_SYNC=postgresql://agentledger:agentledger@db:5432/agentledger
POSTGRES_USER=agentledger
POSTGRES_PASSWORD=agentledger
POSTGRES_DB=agentledger

# Redis
REDIS_URL=redis://redis:6379/0

# API
API_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated API keys accepted for authentication
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=dev-local-only
ADMIN_API_KEYS=dev-local-admin
IP_RATE_LIMIT=100
IP_RATE_WINDOW_SECONDS=60

# Identity / Layer 2
ISSUER_DID=did:web:agentledger.io
# JSON-encoded Ed25519 private JWK used to issue credentials; leave blank until configured
ISSUER_PRIVATE_JWK=
CREDENTIAL_TTL_SECONDS=31536000
PROOF_NONCE_TTL_SECONDS=60
SESSION_ASSERTION_TTL_SECONDS=300
APPROVED_SESSION_TTL_SECONDS=900
AUTHORIZATION_REQUEST_TTL_SECONDS=300
REVOCATION_CACHE_TTL_SECONDS=300
DID_WEB_CACHE_TTL_SECONDS=600
AUTHORIZATION_WEBHOOK_URL=
AUTHORIZATION_WEBHOOK_SECRET=
AUTHORIZATION_WEBHOOK_TIMEOUT_SECONDS=3.0

# Embeddings
# "model" = sentence-transformers
# "hash" = fast CPU-only fallback for CI/load testing
EMBEDDING_MODE=model

# App server
UVICORN_WORKERS=4
