# Database
DATABASE_URL=postgresql+asyncpg://agentledger:agentledger@db:5432/agentledger
DATABASE_URL_SYNC=postgresql://agentledger:agentledger@db:5432/agentledger
POSTGRES_USER=agentledger
POSTGRES_PASSWORD=agentledger
POSTGRES_DB=agentledger

# Redis
REDIS_URL=redis://redis:6379/0

# API
API_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated API keys accepted for authentication
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=dev-local-only
IP_RATE_LIMIT=100
IP_RATE_WINDOW_SECONDS=60

# Embeddings
# "model" = sentence-transformers
# "hash" = fast CPU-only fallback for CI/load testing
EMBEDDING_MODE=model

# App server
UVICORN_WORKERS=4
